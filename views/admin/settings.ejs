<div class="card border-0 shadow-sm rounded-3 p-4 bg-white mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0">Admin Profile Settings</h4>
    <a href="/admin/dashboard" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Back to Dashboard</a>
  </div>

  <form action="/admin/settings" method="POST">
    <!-- CSRF Token -->
    <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">

    <div class="row g-3" style="max-width: 600px;">
      <!-- Name -->
      <div class="col-md-12">
        <label class="form-label text-muted">Admin Full Name</label>
        <input type="text" name="name" class="form-control rounded-3" required value="<%= user.name %>">
      </div>

      <!-- Email/Username -->
      <div class="col-md-12">
        <label class="form-label text-muted">Username / Email Address</label>
        <input type="text" name="email" class="form-control rounded-3" required value="<%= user.email %>">
      </div>

      <!-- New Password -->
      <div class="col-md-12">
        <label class="form-label text-muted">New Password (Leave blank to keep current password)</label>
        <input type="password" name="password" class="form-control rounded-3" placeholder="••••••••">
      </div>
    </div>

    <div class="mt-5 border-top pt-4">
      <button type="submit" class="btn btn-primary px-5 rounded-pill">Save Settings</button>
      <a href="/admin/dashboard" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Cancel</a>
    </div>
  </form>
</div>
