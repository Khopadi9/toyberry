<div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0">Featured Collections Management</h4>
    <a href="/admin/collections/add" class="btn btn-primary btn-sm rounded-pill px-4"><i class="bi bi-plus-lg me-1"></i> Add Collection</a>
  </div>

  <div class="table-responsive">
    <table class="table align-middle">
      <thead>
        <tr class="text-muted small">
          <th>Image</th>
          <th>Button Link</th>
          <th>Card Size</th>
          <th>Status</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (collections && collections.length > 0) { %>
          <% collections.forEach(item => { %>
            <tr id="admin-collection-row-<%= item._id %>">
              <td class="py-3">
                <img src="<%= item.image || '/images/placeholder.png' %>" class="rounded-3" style="width: 100px; height: 60px; object-fit: cover;">
              </td>
              <td>
                <% if (item.buttonLink) { %>
                  <a href="<%= item.buttonLink %>" target="_blank" class="text-decoration-none fw-semibold"><%= item.buttonLink %></a>
                <% } else { %>
                  <span class="text-muted small">None</span>
                <% } %>
              </td>
              <td>
                <span class="badge <%= item.cardSize === 'wide' ? 'bg-info-subtle text-info border-info' : 'bg-warning-subtle text-warning border-warning' %> px-2 py-1 small text-uppercase">
                  <%= item.cardSize %>
                </span>
              </td>
              <td><span class="badge <%= item.status === 'Active' ? 'bg-success' : 'bg-secondary' %> rounded-pill px-3 py-1"><%= item.status %></span></td>
              <td class="text-end">
                <a href="/admin/collections/edit/<%= item._id %>" class="btn btn-sm btn-outline-primary rounded-pill me-2 px-3" title="Edit Collection"><i class="bi bi-pencil-square me-1"></i> Edit</a>
                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="deleteAdminCollection('<%= item._id %>')" title="Delete Collection"><i class="bi bi-trash3 me-1"></i> Delete</button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center text-muted py-5">No collection items found. Click "Add Collection" to create one.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  function deleteAdminCollection(id) {
    showDeleteConfirmation('Are you sure you want to delete this collection card?', async () => {
      try {
        const res = await apiRequest(`/admin/collections/delete/${id}`, 'POST');
        showToast('Success', res.message);
        
        // Remove row
        const el = document.getElementById(`admin-collection-row-${id}`);
        if (el) el.remove();
      } catch (err) {
        showToast('Error', err.message);
      }
    });
  }
</script>
