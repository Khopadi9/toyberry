<div class="card border-0 shadow-sm rounded-3 p-4 bg-white mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0">Edit Featured Collection Card</h4>
    <a href="/admin/collections" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Back to List</a>
  </div>

  <% if (locals.error) { %>
    <div class="alert alert-danger rounded-3" role="alert">
      <%= error %>
    </div>
  <% } %>

  <form action="/admin/collections/edit/<%= collection._id %>" method="POST" enctype="multipart/form-data">
    <!-- CSRF Token -->
    <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">

    <div class="row g-3">
      <!-- Current Image preview -->
      <div class="col-md-12">
        <label class="form-label text-muted d-block fw-bold">Current Background Image</label>
        <img src="<%= collection.image %>" class="rounded-3 border mb-2" style="max-height: 150px; object-fit: contain;">
      </div>

      <!-- Image upload -->
      <div class="col-md-12">
        <label class="form-label text-muted fw-bold">Replace Background Image (Optional)</label>
        <input type="file" name="image" class="form-control rounded-3" accept="image/*">
        <div class="form-text">Leave blank if you wish to keep the current background image.</div>
      </div>

      <!-- Link URL -->
      <div class="col-md-12">
        <label class="form-label text-muted fw-bold">Button Link / Redirect URL (Optional)</label>
        <input type="text" name="buttonLink" class="form-control rounded-3" value="<%= collection.buttonLink %>" placeholder="e.g. /toys?category=educational-toys">
      </div>

      <!-- Card Size -->
      <div class="col-md-6">
        <label class="form-label text-muted fw-bold">Card Layout Size</label>
        <select name="cardSize" class="form-select rounded-3">
          <option value="wide" <%= collection.cardSize === 'wide' ? 'selected' : '' %>>Wide Card (Col-8 Layout)</option>
          <option value="narrow" <%= collection.cardSize === 'narrow' ? 'selected' : '' %>>Narrow Card (Col-4 Layout)</option>
        </select>
        <div class="form-text">Wide cards display horizontal; narrow cards display vertical.</div>
      </div>

      <!-- Status -->
      <div class="col-md-6">
        <label class="form-label text-muted fw-bold">Status</label>
        <select name="status" class="form-select rounded-3">
          <option value="Active" <%= collection.status === 'Active' ? 'selected' : '' %>>Active</option>
          <option value="Inactive" <%= collection.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
        </select>
      </div>
    </div>

    <div class="mt-5 border-top pt-4">
      <button type="submit" class="btn btn-primary px-5 rounded-pill">Save Changes</button>
      <a href="/admin/collections" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Cancel</a>
    </div>
  </form>
</div>
