<div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
  <h4 class="fw-bold mb-4">Orders Management</h4>

  <div class="table-responsive">
    <table class="table align-middle">
      <thead>
        <tr class="text-muted small">
          <th>Order Number</th>
          <th>Customer Name</th>
          <th>Order Date</th>
          <th>Payment Status</th>
          <th>Fulfillment Status</th>
          <th>Grand Total</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (orders && orders.length > 0) { %>
          <% orders.forEach(order => { %>
            <tr>
              <td class="fw-bold"><%= order.orderNumber %></td>
              <td>
                <div class="fw-bold text-dark"><%= order.user ? order.user.name : 'Guest' %></div>
                <div class="text-muted small"><%= order.user ? order.user.email : '' %></div>
              </td>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
              <td>
                <span class="badge <%= order.paymentStatus === 'Paid' ? 'bg-success' : 'bg-warning text-dark' %> rounded-pill px-3 py-1">
                  <%= order.paymentStatus %>
                </span>
              </td>
              <td>
                <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3 py-1">
                  <%= order.orderStatus %>
                </span>
              </td>
              <td class="fw-bold text-primary">₹<%= order.grandTotal.toFixed(2) %></td>
              <td class="text-end">
                <a href="/admin/orders/detail/<%= order._id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">Manage Order</a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" class="text-center text-muted py-5">No orders have been placed yet.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
