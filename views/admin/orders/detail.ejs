<div class="container-fluid pb-5">
  <div class="row g-4">
    <!-- Left Column: Details -->
    <div class="col-lg-8">
      <!-- Order Items -->
      <div class="card border-0 shadow-sm rounded-3 p-4 bg-white mb-4">
        <h5 class="fw-bold mb-4">Order Items</h5>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr class="text-muted small">
                <th>Product</th>
                <th class="text-center">Quantity</th>
                <th class="text-end">Price</th>
                <th class="text-end">Total</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach(item => { %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <img src="<%= item.product ? item.product.images[0] : '/images/placeholder.png' %>" class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover;">
                      <span class="fw-bold text-dark"><%= item.title %></span>
                    </div>
                  </td>
                  <td class="text-center"><%= item.quantity %></td>
                  <td class="text-end">₹<%= item.price.toFixed(2) %></td>
                  <td class="text-end fw-bold text-primary">₹<%= (item.price * item.quantity).toFixed(2) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Shipping & Billing info -->
      <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
        <h5 class="fw-bold mb-4">Shipping Information</h5>
        <div class="row g-3">
          <div class="col-md-6">
            <h6 class="fw-bold text-muted small uppercase">Recipient</h6>
            <div class="text-dark fw-bold"><%= order.shippingAddress.name %></div>
            <div class="text-muted"><%= order.shippingAddress.phone %></div>
          </div>
          <div class="col-md-6">
            <h6 class="fw-bold text-muted small uppercase">Full Address</h6>
            <div class="text-muted">
              <%= order.shippingAddress.addressLine1 %><br>
              <%= order.shippingAddress.addressLine2 || '' %><br>
              <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> <%= order.shippingAddress.postalCode %><br>
              <%= order.shippingAddress.country %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Management panel -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-3 p-4 bg-white mb-4">
        <h5 class="fw-bold mb-4">Update Order</h5>
        
        <form id="admin-order-update-form">
          <input type="hidden" id="order-id-val" value="<%= order._id %>">

          <!-- Order Status -->
          <div class="mb-3">
            <label class="form-label text-muted">Order Status</label>
            <select name="orderStatus" class="form-select rounded-3">
              <option value="Pending" <%= order.orderStatus === 'Pending' ? 'selected' : '' %>>Pending</option>
              <option value="Processing" <%= order.orderStatus === 'Processing' ? 'selected' : '' %>>Processing</option>
              <option value="Shipped" <%= order.orderStatus === 'Shipped' ? 'selected' : '' %>>Shipped</option>
              <option value="Delivered" <%= order.orderStatus === 'Delivered' ? 'selected' : '' %>>Delivered</option>
              <option value="Cancelled" <%= order.orderStatus === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
            </select>
          </div>

          <!-- Payment Status -->
          <div class="mb-3">
            <label class="form-label text-muted">Payment Status</label>
            <select name="paymentStatus" class="form-select rounded-3">
              <option value="Pending" <%= order.paymentStatus === 'Pending' ? 'selected' : '' %>>Pending</option>
              <option value="Paid" <%= order.paymentStatus === 'Paid' ? 'selected' : '' %>>Paid</option>
              <option value="Failed" <%= order.paymentStatus === 'Failed' ? 'selected' : '' %>>Failed</option>
            </select>
          </div>

          <!-- Tracking Number -->
          <div class="mb-4">
            <label class="form-label text-muted">Tracking Number</label>
            <input type="text" name="trackingNumber" class="form-control rounded-3" value="<%= order.trackingNumber || '' %>" placeholder="e.g. FedEx 987654321">
          </div>

          <button type="submit" class="btn btn-primary rounded-pill w-100 py-3 fw-bold">Update Order Details</button>
        </form>
      </div>

      <!-- Financial totals summary -->
      <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
        <h5 class="fw-bold mb-4">Financial Summary</h5>
        <div class="d-flex justify-content-between mb-2 small">
          <span class="text-muted">Subtotal</span>
          <span>₹<%= order.subTotal.toFixed(2) %></span>
        </div>
        <% if (order.coupon) { %>
          <div class="d-flex justify-content-between mb-2 small text-success">
            <span>Discount (<%= order.coupon.code %>)</span>
            <span>-₹<%= order.coupon.discountAmount.toFixed(2) %></span>
          </div>
        <% } %>
        <div class="d-flex justify-content-between mb-2 small">
          <span class="text-muted">Tax</span>
          <span>₹<%= order.tax.toFixed(2) %></span>
        </div>
        <div class="d-flex justify-content-between mb-3 small">
          <span class="text-muted">Shipping</span>
          <span><%= order.shippingFee === 0 ? 'FREE' : `₹${order.shippingFee.toFixed(2)}` %></span>
        </div>
        <hr>
        <div class="d-flex justify-content-between align-items-center">
          <span class="fw-bold">Grand Total</span>
          <span class="fw-bold text-primary fs-5">₹<%= order.grandTotal.toFixed(2) %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('admin-order-update-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const orderId = document.getElementById('order-id-val').value;
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await apiRequest(`/admin/orders/update/${orderId}`, 'POST', data);
      showToast('Success', res.message);
    } catch (err) {
      showToast('Error', err.message);
    }
  });
</script>
