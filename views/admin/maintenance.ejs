<div class="card border-0 shadow-sm rounded-3 p-4 bg-white mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0">Maintenance Mode Control</h4>
    <a href="/admin/dashboard" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Back to Dashboard</a>
  </div>

  <div class="alert alert-info border-0 rounded-4 p-3 mb-4 d-flex align-items-start gap-3">
    <i class="bi bi-info-circle-fill text-primary fs-3"></i>
    <div>
      <h6 class="fw-bold mb-1">About Maintenance Mode</h6>
      <p class="mb-0 text-muted small">
        Enabling maintenance mode will temporarily block access to the public website, showing a beautiful "Under Scheduled Maintenance" splash page to all customers. Admin users will still be able to access the admin panel to turn it off.
      </p>
    </div>
  </div>

  <form action="/admin/maintenance" method="POST">
    <!-- CSRF Token -->
    <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">

    <div class="row g-3" style="max-width: 600px;">
      <!-- Toggle status -->
      <div class="col-md-12">
        <label class="form-label text-muted fw-bold d-block">Status</label>
        
        <div class="form-check form-check-inline me-4 mt-2">
          <input class="form-check-input" type="radio" name="maintenance_mode" id="maintenance_on" value="true" <%= maintenanceEnabled ? 'checked' : '' %>>
          <label class="form-check-label fw-semibold text-danger" for="maintenance_on">
            <i class="bi bi-exclamation-triangle-fill me-1"></i> Maintenance ON
          </label>
        </div>

        <div class="form-check form-check-inline mt-2">
          <input class="form-check-input" type="radio" name="maintenance_mode" id="maintenance_off" value="false" <%= !maintenanceEnabled ? 'checked' : '' %>>
          <label class="form-check-label fw-semibold text-success" for="maintenance_off">
            <i class="bi bi-check-circle-fill me-1"></i> Maintenance OFF (Website Live)
          </label>
        </div>
      </div>
    </div>

    <div class="mt-5 border-top pt-4">
      <button type="submit" class="btn btn-primary px-5 rounded-pill">Update Status</button>
      <a href="/admin/dashboard" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Cancel</a>
    </div>
  </form>
</div>
