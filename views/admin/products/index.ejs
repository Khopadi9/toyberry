<div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0">Products Catalog</h4>
    <div class="d-flex gap-2">
      <a href="/admin/products/add" class="btn btn-primary btn-sm rounded-pill px-4"><i class="bi bi-plus-lg me-1"></i> Add Product</a>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table align-middle">
      <thead>
        <tr class="text-muted small">
          <th>Image</th>

          <th>Product Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Stock</th>
          <th>Status</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (products && products.length > 0) { %>
          <% products.forEach(prod => { %>
            <tr id="admin-prod-row-<%= prod._id %>">
              <td class="py-3">
                <img src="<%= prod.images && prod.images.length > 0 ? prod.images[0] : '/images/placeholder.png' %>" class="rounded-3" style="width: 50px; height: 50px; object-fit: cover;">
              </td>

              <td>
                <div class="fw-bold text-dark"><%= prod.title %></div>
                <div class="text-muted small">Brand: <%= prod.brand ? prod.brand.name : 'N/A' %></div>
              </td>
              <td><%= prod.category ? prod.category.name : 'N/A' %></td>
              <td class="fw-bold text-primary">₹<%= prod.price.toFixed(2) %></td>
              <td>
                <span class="fw-semibold text-dark"><%= prod.stock %> units</span>
              </td>
              <td>
                <% if (prod.status === 'Out of Stock' || prod.stock <= 0) { %>
                  <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-1">Out of Stock</span>
                <% } else { %>
                  <span class="badge bg-success-subtle text-success rounded-pill px-3 py-1">In Stock</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/admin/products/edit/<%= prod._id %>" class="btn btn-sm btn-outline-primary rounded-pill me-2 px-3" title="Edit Product"><i class="bi bi-pencil-square me-1"></i> Edit</a>
                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="deleteAdminProduct('<%= prod._id %>')" title="Delete Product"><i class="bi bi-trash3 me-1"></i> Delete</button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" class="text-center text-muted py-5">No products found in the catalog.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <%- include('../../components/pagination') %>
</div>

<script>
  function deleteAdminProduct(id) {
    showDeleteConfirmation('Are you sure you want to delete this product?', async () => {
      try {
        const res = await apiRequest(`/admin/products/delete/${id}`, 'POST');
        showToast('Success', res.message);
        
        // Remove row
        const el = document.getElementById(`admin-prod-row-${id}`);
        if (el) el.remove();
      } catch (err) {
        showToast('Error', err.message);
      }
    });
  }
</script>
