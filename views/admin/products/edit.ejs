<div class="card border-0 shadow-sm rounded-3 p-4 bg-white mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0">Edit Product: <%= product.title %></h4>
    <a href="/admin/products" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Back to Catalog</a>
  </div>

  <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
    <!-- CSRF Token -->
    <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">

    <div class="row g-3">
      <!-- Title -->
      <div class="col-md-12">
        <label class="form-label text-muted">Product Title</label>
        <input type="text" name="title" class="form-control rounded-3" required value="<%= product.title %>">
      </div>

      <!-- Description -->
      <div class="col-md-12">
        <label class="form-label text-muted">Product Description</label>
        <textarea name="description" class="form-control rounded-3" rows="3" placeholder="Enter product description here..." required><%= product.description || '' %></textarea>
      </div>

      <!-- Price -->
      <div class="col-md-3">
        <label class="form-label text-muted">Regular Price (₹)</label>
        <input type="number" step="0.01" name="price" class="form-control rounded-3" required value="<%= product.price %>" min="0.01">
      </div>

      <!-- Sale Price -->
      <div class="col-md-3">
        <label class="form-label text-muted">Sale Price (₹) (Optional)</label>
        <input type="number" step="0.01" name="salePrice" class="form-control rounded-3" value="<%= product.salePrice || '' %>" min="0.01">
      </div>

      <!-- Stock -->
      <div class="col-md-3">
        <label class="form-label text-muted">Stock Quantity</label>
        <input type="number" name="stock" class="form-control rounded-3" required value="<%= product.stock %>" min="1" step="1">
      </div>

      <!-- Category (Manual Text Input) -->
      <div class="col-md-3">
        <label class="form-label text-muted">Category</label>
        <input type="text" name="category" class="form-control rounded-3" required value="<%= product.category && typeof product.category === 'object' ? product.category.name : '' %>">
      </div>

      <!-- Current Images -->
      <div class="col-md-12">
        <label class="form-label text-muted d-block">Current Images</label>
        <div class="d-flex gap-3 mb-2">
          <% product.images.forEach(img => { %>
            <div class="position-relative">
              <img src="<%= img %>" class="rounded-3" style="width: 85px; height: 85px; object-fit: cover;">
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Image upload -->
      <div class="col-md-9">
        <label class="form-label text-muted">Add More Images</label>
        <input type="file" name="images" class="form-control rounded-3" multiple accept="image/*">
      </div>

      <!-- Product Status -->
      <div class="col-md-3">
        <label class="form-label text-muted">Catalog Status</label>
        <select name="status" class="form-select rounded-3">
          <option value="In Stock" <%= product.status === 'In Stock' ? 'selected' : '' %>>In Stock</option>
          <option value="Out of Stock" <%= product.status === 'Out of Stock' ? 'selected' : '' %>>Out of Stock</option>
        </select>
      </div>

      <!-- Deals of the Week -->
      <div class="col-md-12 mt-3">
        <div class="form-check form-switch p-3 border rounded-3 bg-light">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <div>
              <label class="form-check-label fw-bold text-dark mb-1" for="isDealOfTheWeek" style="cursor: pointer;">Deals of the Week</label>
              <div class="text-muted small">Show this product on the homepage under "Deals of the Week" banner.</div>
            </div>
            <input class="form-check-input ms-0" type="checkbox" name="isDealOfTheWeek" id="isDealOfTheWeek" value="true" <%= product.isDealOfTheWeek ? 'checked' : '' %> style="width: 2.8em; height: 1.5em; cursor: pointer;" onchange="toggleDiscountField()">
          </div>
          <% 
            let currentDiscountPct = '';
            if (product.price && product.salePrice && product.salePrice < product.price) {
              currentDiscountPct = Math.round(((product.price - product.salePrice) / product.price) * 100);
            }
          %>
          <div id="discount-pct-wrapper" style="display: <%= product.isDealOfTheWeek ? 'block' : 'none' %>;" class="mt-3 pt-3 border-top">
            <label class="form-label text-muted small fw-bold">Discount Percentage (%)</label>
            <div class="input-group" style="max-width: 200px;">
              <input type="number" name="discountPercentage" id="discountPercentage" class="form-control rounded-3" placeholder="e.g. 14" value="<%= currentDiscountPct %>" min="0" max="100">
              <span class="input-group-text">% OFF</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-5 border-top pt-4">
      <button type="submit" class="btn btn-primary px-5 rounded-pill">Update Product</button>
      <a href="/admin/products" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Cancel</a>
    </div>
  </form>
</div>

<script>
  function toggleDiscountField() {
    const isChecked = document.getElementById('isDealOfTheWeek').checked;
    document.getElementById('discount-pct-wrapper').style.display = isChecked ? 'block' : 'none';
  }
</script>
