<div class="card border-0 shadow-sm rounded-3 p-4 bg-white mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0">Add New Product</h4>
    <a href="/admin/products" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Back to Catalog</a>
  </div>

  <form action="/admin/products/add" method="POST" enctype="multipart/form-data">
    <!-- CSRF Token -->
    <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">

    <div class="row g-3">
      <!-- Title -->
      <div class="col-md-12">
        <label class="form-label text-muted">Product Title</label>
        <input type="text" name="title" class="form-control rounded-3" required placeholder="e.g. Remote Control Supercar">
      </div>

      <!-- Description -->
      <div class="col-md-12">
        <label class="form-label text-muted">Product Description</label>
        <textarea name="description" class="form-control rounded-3" rows="3" placeholder="Enter product description here..." required></textarea>
      </div>

      <!-- Price -->
      <div class="col-md-3">
        <label class="form-label text-muted">Regular Price (₹)</label>
        <input type="number" step="0.01" name="price" class="form-control rounded-3" required placeholder="2499" min="0.01">
      </div>

      <!-- Sale Price -->
      <div class="col-md-3">
        <label class="form-label text-muted">Sale Price (₹) (Optional)</label>
        <input type="number" step="0.01" name="salePrice" class="form-control rounded-3" placeholder="1999" min="0.01">
      </div>

      <!-- Stock -->
      <div class="col-md-3">
        <label class="form-label text-muted">Stock Quantity</label>
        <input type="number" name="stock" class="form-control rounded-3" required placeholder="10" min="1" step="1">
      </div>

      <!-- Category (Manual Text Input) -->
      <div class="col-md-3">
        <label class="form-label text-muted">Category</label>
        <input type="text" name="category" class="form-control rounded-3" required placeholder="e.g. Building Blocks">
      </div>

      <!-- Image upload -->
      <div class="col-md-9">
        <label class="form-label text-muted">Product Images (Upload up to 5 files)</label>
        <input type="file" name="images" class="form-control rounded-3" multiple accept="image/*">
      </div>

      <!-- Product Status -->
      <div class="col-md-3">
        <label class="form-label text-muted">Catalog Status</label>
        <select name="status" class="form-select rounded-3">
          <option value="In Stock">In Stock</option>
          <option value="Out of Stock">Out of Stock</option>
        </select>
      </div>

      <!-- Deals of the Week -->
      <div class="col-md-12 mt-3">
        <div class="form-check form-switch p-3 border rounded-3 bg-light">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <div>
              <label class="form-check-label fw-bold text-dark mb-1" for="isDealOfTheWeek" style="cursor: pointer;">Deals of the Week</label>
              <div class="text-muted small">Show this product on the homepage under "Deals of the Week" banner.</div>
            </div>
            <input class="form-check-input ms-0" type="checkbox" name="isDealOfTheWeek" id="isDealOfTheWeek" value="true" style="width: 2.8em; height: 1.5em; cursor: pointer;" onchange="toggleDiscountField()">
          </div>
          <div id="discount-pct-wrapper" style="display: none;" class="mt-3 pt-3 border-top">
            <label class="form-label text-muted small fw-bold">Discount Percentage (%)</label>
            <div class="input-group" style="max-width: 200px;">
              <input type="number" name="discountPercentage" id="discountPercentage" class="form-control rounded-3" placeholder="e.g. 14" min="0" max="100">
              <span class="input-group-text">% OFF</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-5 border-top pt-4">
      <button type="submit" class="btn btn-primary px-5 rounded-pill">Create Product</button>
      <a href="/admin/products" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Cancel</a>
    </div>
  </form>
</div>

<script>
  function toggleDiscountField() {
    const isChecked = document.getElementById('isDealOfTheWeek').checked;
    document.getElementById('discount-pct-wrapper').style.display = isChecked ? 'block' : 'none';
  }
</script>
