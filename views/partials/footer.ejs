<script>
  // Simple cookie consent logic
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.getElementById('cookie-consent-banner');
    const acceptBtn = document.getElementById('btn-accept-cookies');
    
    if (banner && !localStorage.getItem('cookies-accepted')) {
      banner.classList.remove('d-none');
    }
    
    if (acceptBtn && banner) {
      acceptBtn.addEventListener('click', () => {
        localStorage.setItem('cookies-accepted', 'true');
        banner.classList.add('d-none');
      });
    }

    // Floating Contact Widget Logic
    const toggleBtn = document.getElementById('contact-toggle-btn');
    const contactCard = document.getElementById('contact-popup-card');
    const closeBtn = document.getElementById('close-contact-popup');
    
    if (toggleBtn && contactCard) {
      toggleBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        contactCard.classList.toggle('show');
      });
      
      if (closeBtn) {
        closeBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          contactCard.classList.remove('show');
        });
      }
      
      // Close on click outside
      document.addEventListener('click', (e) => {
        if (!contactCard.contains(e.target) && !toggleBtn.contains(e.target)) {
          contactCard.classList.remove('show');
        }
      });
    }
  });
</script>

