<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Favicon -->
  <link rel="icon" type="image/jpeg" href="/uploads/toyberry.jpg">

  <!-- CSRF Token -->
  <% if (locals.csrfToken) { %>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <% } %>

      <!-- Dynamic SEO Meta Tags -->
      <% if (locals.seo) { %>
        <title>
          <%= seo.title || 'ToyBerry - Premium Toys Store' %>
        </title>
        <meta name="description" content="<%= seo.description || '' %>">
        <meta name="keywords" content="<%= seo.keywords || '' %>">
        <meta property="og:title" content="<%= seo.title || '' %>">
        <meta property="og:description" content="<%= seo.description || '' %>">
        <meta property="og:type" content="website">
        <meta property="og:url" content="<%= locals.url || '' %>">
        <meta property="og:image" content="<%= locals.image || '/images/logo.png' %>">
        <% } else { %>
          <title>
            <%= title %> | ToyBerry
          </title>
          <meta name="description" content="Shop premium, luxury, and educational toys at ToyBerry.">
          <% } %>

            <!-- Bootstrap 5 CSS -->
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
            <!-- Bootstrap Icons -->
            <link rel="stylesheet"
              href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
            <!-- Custom Stylesheet -->
            <link rel="stylesheet" href="/css/style.css">
</head>

<body class="<%= (locals.title === 'Premium Toys Store' || locals.activePage === 'home') ? 'home-page-active' : '' %>">

  <!-- Header Partial -->
  <%- include('../partials/header') %>

    <!-- Main View Content -->
    <main
      style="min-height: 70vh; <%= (locals.title === 'Premium Toys Store' || locals.activePage === 'home') ? '' : 'padding-top: 88px;' %>">
      <%- body %>
    </main>

    <!-- Footer Partial -->
    <%- include('../partials/footer') %>

      <!-- Bootstrap 5 Bundle JS -->
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
      <!-- Global Custom JS -->
      <script src="/js/main.js"></script>

      <!-- Session toasts -->
      <% if (locals.sessionToast) { %>
        <script>
          document.addEventListener('DOMContentLoaded', () => {
            showToast('<%= sessionToast.type %>', '<%= sessionToast.message %>');
            if (window.history && window.history.replaceState) {
              const url = new URL(window.location.href);
              if (url.searchParams.has('toastType') || url.searchParams.has('toastMessage')) {
                url.searchParams.delete('toastType');
                url.searchParams.delete('toastMessage');
                window.history.replaceState({}, document.title, url.pathname + url.search);
              }
            }
          });
        </script>
        <% } %>
</body>

</html>