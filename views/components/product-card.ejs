<% const isOutOfStock=product.stock <=0 || product.status==='Out of Stock' ; const originalPrice=product.price; const
  finalPrice=product.salePrice || product.price; const hasDiscount=product.salePrice && product.salePrice <
  product.price; const discountPct=hasDiscount ? Math.round(((product.price - product.salePrice) / product.price) * 100)
  : 0; const primaryImg=product.images && product.images.length> 0 ? product.images[0] : '/images/placeholder.png';
  const secondaryImg = product.images && product.images.length > 1 ? product.images[1] : primaryImg;
  %>

  <div class="card card-premium h-100">
    <div class="product-card-img-wrapper">
      <% if (locals.showDiscountBadge && hasDiscount) { %>
        <span class="badge bg-danger position-absolute"
          style="top: 15px; left: 15px; z-index: 5; padding: 6px 10px; font-weight: 800; font-size: 0.72rem; border-radius: var(--radius-sm);">
          <%= discountPct %>% OFF
        </span>
        <% } %>

          <!-- Product Image -->
          <a href="/toys/<%= product.slug %>">
            <img src="<%= primaryImg %>" class="product-card-img" alt="<%= product.title %>" loading="lazy"
              onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1559251606-c623743a6d76?auto=format&fit=crop&q=80&w=400';">
          </a>

          <!-- Quick View button overlay -->
          <div class="quick-view-overlay">
            <button class="btn btn-quick-view w-100 shadow-sm" data-action="quick-view"
              data-product-id="<%= product._id %>">
              <i class="bi bi-eye me-1"></i> Quick View
            </button>
          </div>
    </div>

    <div class="card-body d-flex flex-column">

      <h5 class="card-title mb-2">
        <a href="/toys/<%= product.slug %>" class="text-white text-decoration-none hover-color-primary fw-bold"
          style="font-size: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3rem; line-height: 1.5;">
          <%= product.title %>
        </a>
      </h5>



      <!-- Pricing and Availability Status -->
      <div class="mt-auto d-flex justify-content-between align-items-center pt-2">
        <div>
          <% if (hasDiscount) { %>
            <div class="text-decoration-line-through text-muted" style="font-size: 0.82rem;">₹<%=
                originalPrice.toFixed(2) %>
            </div>
            <div class="text-primary fw-extrabold fs-5">₹<%= finalPrice.toFixed(2) %>
            </div>
            <% } else { %>
              <div class="text-white fw-extrabold fs-5">₹<%= finalPrice.toFixed(2) %>
              </div>
              <% } %>
        </div>

        <!-- Offline Availability Status -->
        <% if (isOutOfStock) { %>
          <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1.5 fw-bold"
            style="font-size: 0.72rem; border-radius: var(--radius-sm);">Out of Stock</span>
          <% } else { %>
            <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1.5 fw-bold"
              style="font-size: 0.72rem; border-radius: var(--radius-sm);">In Store</span>
            <% } %>
      </div>
    </div>
  </div>