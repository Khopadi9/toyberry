<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <h1 class="fw-bold mb-4 text-center">Track Your Order</h1>

      <!-- Search Box -->
      <div class="card border-0 shadow-sm rounded-4 p-4 mb-5">
        <form action="/order/track" method="GET">
          <label class="form-label text-muted fw-semibold">Enter your 12-digit Order Number</label>
          <div class="input-group">
            <input type="text" name="orderNumber" class="form-control rounded-start-pill px-4 shadow-sm" placeholder="e.g. TB-12345678" value="<%= orderNumber || '' %>" required>
            <button class="btn btn-primary-custom rounded-end-pill px-4" type="submit">Track Status</button>
          </div>
        </form>
      </div>

      <!-- Tracking Results -->
      <% if (order) { %>
        <!-- Progress Steps -->
        <div class="card border-0 shadow-sm rounded-4 p-5 mb-4">
          <div class="row text-center mb-5 justify-content-center">
            <% 
              const states = ['Pending', 'Processing', 'Shipped', 'Delivered'];
              const currentIdx = states.indexOf(order.orderStatus);
            %>
            
            <% states.forEach((state, idx) => { %>
              <div class="col-3 position-relative">
                <!-- Circle Step Indicator -->
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-2" 
                     style="width: 50px; height: 50px; font-size: 1.2rem; 
                            background-color: <%= idx <= currentIdx ? 'var(--primary-color)' : '#e9ecef' %>; 
                            color: <%= idx <= currentIdx ? '#fff' : '#6c757d' %>;">
                  <% if (state === 'Pending') { %><i class="bi bi-clock"></i><% } %>
                  <% if (state === 'Processing') { %><i class="bi bi-gear"></i><% } %>
                  <% if (state === 'Shipped') { %><i class="bi bi-box-seam"></i><% } %>
                  <% if (state === 'Delivered') { %><i class="bi bi-house-check"></i><% } %>
                </div>
                
                <h6 class="fw-bold mb-0 <%= idx <= currentIdx ? 'text-primary' : 'text-muted' %>" style="font-size: 0.9rem;"><%= state %></h6>
                
                <!-- Connector Line -->
                <% if (idx < states.length - 1) { %>
                  <div class="position-absolute top-50 start-50 translate-middle-y w-100" 
                       style="height: 4px; background-color: <%= idx < currentIdx ? 'var(--primary-color)' : '#e9ecef' %>; 
                              z-index: -1; left: 25px;"></div>
                <% } %>
              </div>
            <% }) %>
          </div>

          <!-- Order details -->
          <div class="row g-4 border-top pt-4">
            <div class="col-md-6">
              <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size: 0.75rem;">Delivery Address</h6>
              <div class="fw-bold text-dark"><%= order.shippingAddress.name %></div>
              <div class="text-muted small">
                <%= order.shippingAddress.addressLine1 %><br>
                <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> <%= order.shippingAddress.postalCode %><br>
                Phone: <%= order.shippingAddress.phone %>
              </div>
            </div>

            <div class="col-md-6">
              <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size: 0.75rem;">Shipment Meta</h6>
              <div class="mb-2"><strong>Status:</strong> <span class="badge bg-secondary-subtle text-secondary px-3 py-1 rounded-pill"><%= order.orderStatus %></span></div>
              <div class="mb-2"><strong>Payment Method:</strong> <%= order.paymentMethod %></div>
              <% if (order.trackingNumber) { %>
                <div><strong>Tracking Number:</strong> <span class="text-primary fw-bold"><%= order.trackingNumber %></span></div>
              <% } else { %>
                <div><strong>Tracking Number:</strong> <span class="text-muted">Awaiting fulfillment...</span></div>
              <% } %>
            </div>
          </div>
        </div>
      <% } else if (orderNumber) { %>
        <div class="alert alert-danger rounded-4 text-center p-4">
          <i class="bi bi-exclamation-triangle fs-2 d-block mb-2"></i>
          <strong>Order not found!</strong> Please verify the order number and try again.
        </div>
      <% } %>
    </div>
  </div>
</div>
