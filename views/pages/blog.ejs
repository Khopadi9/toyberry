<div class="container py-4">
  <%- include('../components/breadcrumb', { breadcrumbs: [{ name: 'Blog', url: '/blog' }] }) %>

  <div class="row">
    <!-- Blog posts grid -->
    <div class="col-lg-8">
      <h2 class="fw-bold mb-4">Playtime Insights & Guides</h2>

      <% if (blogs && blogs.length > 0) { %>
        <div class="row g-4">
          <% blogs.forEach(blog => { %>
            <div class="col-md-6">
              <div class="card card-premium h-100">
                <img src="<%= blog.image || '/images/placeholder-blog.png' %>" class="card-img-top" alt="<%= blog.title %>" style="height: 200px; object-fit: cover;">
                <div class="card-body p-4 d-flex flex-column">
                  <div>
                    <span class="badge bg-primary-subtle text-primary mb-2" style="font-size: 0.75rem;"><%= blog.category %></span>
                    <h4 class="card-title fw-bold fs-5 mb-2"><a href="/blog/<%= blog.slug %>" class="text-dark text-decoration-none"><%= blog.title %></a></h4>
                    <p class="text-muted small mb-3" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;"><%= blog.content.substring(0, 150) %>...</p>
                  </div>
                  <div class="mt-auto d-flex justify-content-between align-items-center pt-3 border-top">
                    <small class="text-muted"><%= new Date(blog.createdAt).toLocaleDateString() %></small>
                    <a href="/blog/<%= blog.slug %>" class="btn btn-primary-custom btn-sm rounded-pill px-3">Read More</a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="text-center py-5">
          <i class="bi bi-journal-x fs-1 text-muted"></i>
          <h4 class="fw-bold mt-3">No articles found</h4>
          <p class="text-muted">Try clearing your filters or searches.</p>
          <a href="/blog" class="btn btn-outline-primary rounded-pill mt-2">Reset Blog</a>
        </div>
      <% } %>
    </div>

    <!-- Right Sidebar Widgets -->
    <div class="col-lg-4">
      <div class="sticky-top" style="top: 110px;">
        <!-- Search widget -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
          <h5 class="fw-bold mb-3">Search Articles</h5>
          <form action="/blog" method="GET">
            <div class="input-group">
              <input type="text" name="search" class="form-control rounded-start-pill px-3 shadow-sm" placeholder="Search..." value="<%= filters.search || '' %>">
              <button class="btn btn-secondary-custom rounded-end-pill px-3" type="submit"><i class="bi bi-search"></i></button>
            </div>
          </form>
        </div>

        <!-- Categories widget -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
          <h5 class="fw-bold mb-3">Categories</h5>
          <div class="list-group list-group-flush">
            <a href="/blog" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0 fw-medium">
              All Categories
            </a>
            <% categories.forEach(cat => { %>
              <a href="/blog?category=<%= cat %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0 fw-medium <%= filters.category === cat ? 'text-primary' : '' %>">
                <%= cat %>
              </a>
            <% }) %>
          </div>
        </div>

        <!-- Popular posts widget -->
        <div class="card border-0 shadow-sm rounded-4 p-4">
          <h5 class="fw-bold mb-3">Popular Posts</h5>
          <div class="d-flex flex-column gap-3">
            <% popular.forEach(post => { %>
              <div class="d-flex align-items-center">
                <img src="<%= post.image || '/images/placeholder-blog.png' %>" class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover;">
                <div>
                  <h6 class="fw-bold mb-0" style="font-size: 0.85rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    <a href="/blog/<%= post.slug %>" class="text-dark text-decoration-none"><%= post.title %></a>
                  </h6>
                  <small class="text-muted" style="font-size: 0.7rem;"><%= new Date(post.createdAt).toLocaleDateString() %></small>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
