<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5 py-4">
      <div class="card border-0 shadow-sm rounded-4 p-5">
        <!-- Step 1: Send OTP -->
        <div id="step-send-otp">
          <h2 class="fw-bold mb-2 text-center">Reset Password</h2>
          <p class="text-muted mb-4 text-center">Enter your email and we'll send you a password reset OTP code</p>

          <form id="forgot-password-email-form">
            <!-- CSRF Token -->
            <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">

            <div class="mb-4">
              <label class="form-label text-muted">Email Address</label>
              <input type="email" name="email" id="reset-email" class="form-control rounded-pill px-4 shadow-sm" placeholder="name@domain.com" required>
            </div>

            <button type="submit" class="btn btn-primary-custom rounded-pill w-100 py-3 fw-bold mb-3">Send OTP Code</button>
          </form>
        </div>

        <!-- Step 2: Reset Form (Hidden initially) -->
        <div id="step-reset-form" class="d-none">
          <h2 class="fw-bold mb-2 text-center">Enter New Password</h2>
          <p class="text-muted mb-4 text-center">Input the OTP code sent to your email and your new password</p>

          <form id="reset-password-submit-form">
            <!-- CSRF Token -->
            <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
            <input type="hidden" name="email" id="reset-email-hidden">

            <div class="mb-3">
              <label class="form-label text-muted">6-Digit OTP Code</label>
              <input type="text" name="code" class="form-control rounded-pill text-center fs-5 shadow-sm" maxlength="6" required placeholder="000000">
            </div>

            <div class="mb-4">
              <label class="form-label text-muted">New Password</label>
              <input type="password" name="newPassword" class="form-control rounded-pill px-4 shadow-sm" required placeholder="••••••••">
            </div>

            <button type="submit" class="btn btn-primary-custom rounded-pill w-100 py-3 fw-bold mb-3">Save New Password</button>
          </form>
        </div>

        <p class="text-center text-muted mb-0 small">
          Remember your password? <a href="/login" class="text-decoration-none text-primary fw-semibold">Sign In</a>
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  // Step 1: Send OTP
  document.getElementById('forgot-password-email-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('reset-email').value;

    try {
      const res = await apiRequest('/forgot-password', 'POST', { email });
      showToast('Success', res.message);
      
      // Move to Step 2
      document.getElementById('reset-email-hidden').value = email;
      document.getElementById('step-send-otp').classList.add('d-none');
      document.getElementById('step-reset-form').classList.remove('d-none');
    } catch (err) {
      showToast('Error', err.message || 'Failed to send OTP code');
    }
  });

  // Step 2: Reset Submit
  document.getElementById('reset-password-submit-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await apiRequest('/reset-password', 'POST', data);
      showToast('Success', res.message);
      
      // Redirect to login
      setTimeout(() => {
        window.location.href = '/login';
      }, 1500);
    } catch (err) {
      showToast('Error', err.message || 'Failed to reset password');
    }
  });
</script>
