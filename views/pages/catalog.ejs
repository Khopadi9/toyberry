<!-- Script Logic to update AJAX Catalog -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterForm = document.getElementById('catalog-filter-form');
    const productGrid = document.getElementById('product-grid-container');
    const paginationContainer = document.getElementById('pagination-container');
    const countIndicator = document.getElementById('catalog-count-indicator');

    const categoryButtons = document.querySelectorAll('.category-pill-btn');
    const activeCategoryInput = document.getElementById('activeCategoryInput');
    
    const ageButtons = document.querySelectorAll('.age-pill-btn');
    const ageRangeInput = document.getElementById('ageRangeInput');

    // Helper to render product card client side
    function renderProductCard(product) {
      const isOutOfStock = product.stock <= 0 || product.status === 'Out of Stock';
      const originalPrice = product.price;
      const finalPrice = product.salePrice || product.price;
      const hasDiscount = product.salePrice && product.salePrice < product.price;
      const discountPct = hasDiscount ? Math.round(((product.price - product.salePrice) / product.price) * 100) : 0;
      
      const primaryImg = product.images && product.images.length > 0 ? product.images[0] : '/images/placeholder.png';
      const categoryName = product.category && product.category.name ? product.category.name : 'Toys';
      
      let badgeHtml = '';
      if (hasDiscount) {
        badgeHtml = `<span class="badge-tag-custom bg-danger text-white">${discountPct}% OFF</span>`;
      } else if (product.isFeatured) {
        badgeHtml = '<span class="badge-tag-custom bg-dark text-white">FEATURED</span>';
      } else if (product.isNewArrival) {
        badgeHtml = '<span class="badge-tag-custom bg-primary text-white">NEW</span>';
      }
      
      let actionBtnHtml = `<button class="btn btn-quick-view-card w-100" data-action="quick-view" data-product-id="${product._id}">QUICK VIEW</button>`;

      return `
        <div class="col">
          <div class="catalog-product-card">
            <div class="catalog-card-img-wrapper">
              <div class="card-badge-container">
                ${badgeHtml}
              </div>
              <button class="wishlist-btn-circle" data-action="wishlist" data-product-id="${product._id}">
                <i class="bi bi-heart"></i>
              </button>
              <a href="/toys/${product.slug}">
                <img src="${primaryImg}" class="catalog-card-img" alt="${product.title}" loading="lazy" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1559251606-c623743a6d76?auto=format&fit=crop&q=80&w=400';">
              </a>
              ${isOutOfStock ? `
                <div class="out-of-stock-overlay-diagonal">
                  <span>OUT OF STOCK</span>
                </div>
              ` : ''}
            </div>
            <div class="catalog-card-body">
              <div class="catalog-card-category">${categoryName.toUpperCase()}</div>
              <h3 class="catalog-card-title">
                <a href="/toys/${product.slug}">${product.title}</a>
              </h3>
              <p class="catalog-card-desc">${product.shortDescription || 'Heirloom quality build. Designed to stimulate imagination and cognitive growth.'}</p>
              <div class="d-flex justify-content-between align-items-center mt-auto pt-2">
                <div class="catalog-card-price">
                  ${hasDiscount ? `
                    <span class="price-original">₹${originalPrice.toFixed(2)}</span>
                    <span class="price-final text-danger">₹${finalPrice.toFixed(2)}</span>
                  ` : `
                    <span class="price-final">₹${finalPrice.toFixed(2)}</span>
                  `}
                </div>
                <span class="stock-indicator ${isOutOfStock ? 'out-of-stock' : 'in-store'}">${isOutOfStock ? 'Out of Stock' : 'In Store'}</span>
              </div>
            </div>
            <div class="catalog-card-actions">
              ${actionBtnHtml}
            </div>
          </div>
        </div>
      `;
    }

    // Helper to render pagination controls
    function renderPaginationControls(pagination) {
      if (!pagination || pagination.totalPages <= 1) return '';

      let html = `
        <nav aria-label="Page navigation" class="mt-5">
          <ul class="pagination justify-content-center">
      `;

      const prevDisabled = !pagination.hasPrevPage ? 'disabled' : '';
      html += `
        <li class="page-item ${prevDisabled}">
          <a class="page-link" href="#" data-page="${pagination.prevPage}" aria-label="Previous">
            <i class="bi bi-chevron-left"></i>
          </a>
        </li>
      `;

      for (let i = 1; i <= pagination.totalPages; i++) {
        const activeClass = pagination.page === i ? 'active' : '';
        html += `
          <li class="page-item ${activeClass}">
            <a class="page-link" href="#" data-page="${i}">
              ${i}
            </a>
          </li>
        `;
      }

      const nextDisabled = !pagination.hasNextPage ? 'disabled' : '';
      html += `
        <li class="page-item ${nextDisabled}">
          <a class="page-link" href="#" data-page="${pagination.nextPage}" aria-label="Next">
            <i class="bi bi-chevron-right"></i>
          </a>
        </li>
      `;

      html += `
          </ul>
        </nav>
      `;

      return html;
    }

    // Function to run AJAX call
    async function updateCatalog(pageNumber = 1) {
      const formData = new FormData(filterForm);
      const params = new URLSearchParams();

      for (const [key, value] of formData.entries()) {
        if (value && key !== 'inStore' && key !== 'outOfStock') {
          params.append(key, value);
        }
      }

      // Explicitly set inStore and outOfStock status
      const inStoreCheck = document.getElementById('inStoreCheck');
      const outOfStockCheck = document.getElementById('outOfStockCheck');
      if (inStoreCheck) {
        params.set('inStore', inStoreCheck.checked ? 'true' : 'false');
      }
      if (outOfStockCheck) {
        params.set('outOfStock', outOfStockCheck.checked ? 'true' : 'false');
      }

      // Also get sort selector from outside form
      const sortSelect = document.querySelector('select[name="sort"]');
      if (sortSelect && sortSelect.value) {
        params.set('sort', sortSelect.value);
      }

      params.set('page', pageNumber);

      const queryString = params.toString();
      const fetchUrl = `/toys?${queryString}`;

      window.history.pushState(null, '', fetchUrl);
      productGrid.style.opacity = '0.5';

      try {
        const res = await apiRequest(fetchUrl);
        const products = res.data.products || [];
        const pagination = res.data.pagination || {};

        if (products.length === 0) {
          productGrid.innerHTML = `
            <div class="col-12 text-center py-5">
              <div class="py-5">
                <i class="bi bi-emoji-frown fs-1 text-muted mb-3"></i>
                <h4 class="fw-bold text-dark">No Toys Found</h4>
                <p class="text-muted">Try adjusting your filters or search criteria</p>
                <button type="button" id="btn-reset-catalog" class="btn btn-apply-filters rounded-pill mt-3 px-4">Reset Catalog</button>
              </div>
            </div>
          `;
        } else {
          productGrid.innerHTML = products.map(p => renderProductCard(p)).join('');
        }

        if (countIndicator) {
          countIndicator.textContent = products.length;
        }

        paginationContainer.innerHTML = renderPaginationControls(pagination);
      } catch (err) {
        showToast('Error', err.message || 'Failed to update catalog.');
      } finally {
        productGrid.style.opacity = '1';
      }
    }

    // Function to clear all filters
    function clearFilters() {
      filterForm.reset();
      
      // Clean text / number inputs
      filterForm.querySelectorAll('input').forEach(input => {
        if (input.type !== 'hidden') {
          input.value = '';
          if (input.type === 'checkbox') input.checked = false;
        }
      });

      // Default checkbox state to match first load (In Store checked, Out of Stock unchecked)
      const inStoreCheck = document.getElementById('inStoreCheck');
      if (inStoreCheck) inStoreCheck.checked = true;
      const outOfStockCheck = document.getElementById('outOfStockCheck');
      if (outOfStockCheck) outOfStockCheck.checked = false;

      // Clear hidden values
      activeCategoryInput.value = '';
      ageRangeInput.value = '';
      
      const searchHidden = filterForm.querySelector('input[name="search"]');
      if (searchHidden) {
        searchHidden.value = '';
      }
      
      const headerSearch = document.getElementById('global-search-input'); 
      if (headerSearch) {
        headerSearch.value = '';
      }

      // Reset pill classes
      categoryButtons.forEach(b => b.classList.remove('active'));
      const allCatBtn = document.querySelector('.category-pill-btn[data-category=""]');
      if (allCatBtn) allCatBtn.classList.add('active');
      
      ageButtons.forEach(b => b.classList.remove('active'));
      
      updateCatalog(1);
    }

    // Category button click handlers
    categoryButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        categoryButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategoryInput.value = btn.getAttribute('data-category');
        updateCatalog(1);
      });
    });

    // Age button click handlers
    ageButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.classList.contains('active')) {
          btn.classList.remove('active');
          ageRangeInput.value = '';
        } else {
          ageButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          ageRangeInput.value = btn.getAttribute('data-age');
        }
        updateCatalog(1);
      });
    });

    // Sort select listener
    const sortSelect = document.querySelector('select[name="sort"]');
    if (sortSelect) {
      sortSelect.addEventListener('change', () => {
        updateCatalog(1);
      });
    }

    // Checkbox state change listeners
    filterForm.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        updateCatalog(1);
      });
    });

    // Debounced listener on price inputs
    let priceTimeout = null;
    filterForm.querySelectorAll('input[type="number"]').forEach(elem => {
      elem.addEventListener('input', () => {
        clearTimeout(priceTimeout);
        priceTimeout = setTimeout(() => {
          updateCatalog(1);
        }, 450);
      });
    });

    // Intercept form submit
    filterForm.addEventListener('submit', (e) => {
      e.preventDefault();
      updateCatalog(1);
    });

    // Intercept clear all click
    const clearBtn = document.getElementById('btn-clear-all');
    if (clearBtn) {
      clearBtn.addEventListener('click', clearFilters);
    }

    // Delegate reset click
    document.addEventListener('click', (e) => {
      if (e.target && e.target.id === 'btn-reset-catalog') {
        clearFilters();
      }
    });

    // Intercept clicks on pagination elements
    paginationContainer.addEventListener('click', (e) => {
      const link = e.target.closest('a.page-link');
      if (link) {
        e.preventDefault();
        const page = link.getAttribute('data-page');
        if (page) {
          updateCatalog(parseInt(page));
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      }
    });
  });
</script>
