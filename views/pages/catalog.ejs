<div class="catalog-page-wrapper">
  <div class="container">

    <!-- Header Row -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-5 mt-3">
      <div>
        <h1 class="catalog-title">Every toy, one place.</h1>
      </div>
      <div class="sort-dropdown-wrap d-flex align-items-center gap-2">
        <span class="sort-label">SORT BY:</span>
        <select name="sort" class="form-select sort-select-custom" form="catalog-filter-form">
          <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest Arrivals</option>
          <option value="price-low" <%= filters.sort === 'price-low' ? 'selected' : '' %>>Price: Low to High</option>
          <option value="price-high" <%= filters.sort === 'price-high' ? 'selected' : '' %>>Price: High to Low</option>
        </select>
      </div>
    </div>

    <!-- Horizontal Filters Bar -->
    <div class="horizontal-filter-bar mb-4">
      <form action="/toys" method="GET" id="catalog-filter-form" class="row align-items-center g-0">
        
        <!-- Price Range -->
        <div class="col-lg-3 col-md-6 filter-col pe-4 mb-3 mb-lg-0">
          <label class="filter-label">PRICE RANGE</label>
          <div class="d-flex align-items-center gap-2">
            <div class="price-input-wrapper">
              <span class="currency-symbol">₹</span>
              <input type="number" name="minPrice" id="minPriceInput" class="filter-input-price" placeholder="0" value="<%= filters.minPrice || '' %>" min="0">
            </div>
            <span class="filter-separator">-</span>
            <div class="price-input-wrapper">
              <span class="currency-symbol">₹</span>
              <input type="number" name="maxPrice" id="maxPriceInput" class="filter-input-price" placeholder="500" value="<%= filters.maxPrice || '' %>" min="0">
            </div>
          </div>
        </div>
        
        <!-- Availability -->
        <div class="col-lg-3 col-md-6 filter-col px-lg-4 mb-3 mb-lg-0">
          <label class="filter-label">AVAILABILITY</label>
          <div class="d-flex align-items-center gap-3">
            <div class="form-check custom-checkbox-wrap mb-0">
              <% 
                const displayInStore = (filters.inStore === undefined && filters.outOfStock === undefined) ? 'true' : filters.inStore;
                const displayOutOfStock = (filters.inStore === undefined && filters.outOfStock === undefined) ? 'false' : filters.outOfStock;
              %>
              <input class="form-check-input" type="checkbox" name="inStore" id="inStoreCheck" value="true" <%= displayInStore === 'true' ? 'checked' : '' %>>
              <label class="form-check-label" for="inStoreCheck">In Store</label>
            </div>
            <div class="form-check custom-checkbox-wrap mb-0">
              <input class="form-check-input" type="checkbox" name="outOfStock" id="outOfStockCheck" value="true" <%= displayOutOfStock === 'true' ? 'checked' : '' %>>
              <label class="form-check-label" for="outOfStockCheck">Out of Stock</label>
            </div>
          </div>
        </div>

        <!-- Age Range -->
        <div class="col-lg-3 col-md-6 filter-col px-lg-4 mb-3 mb-lg-0">
          <label class="filter-label">AGE RANGE</label>
          <div class="d-flex gap-2">
            <input type="hidden" name="ageRange" id="ageRangeInput" value="<%= filters.ageRange || '' %>">
            <button type="button" class="btn age-pill-btn <%= filters.ageRange === '0-3' ? 'active' : '' %>" data-age="0-3">0-3</button>
            <button type="button" class="btn age-pill-btn <%= filters.ageRange === '4-8' ? 'active' : '' %>" data-age="4-8">4-8</button>
            <button type="button" class="btn age-pill-btn <%= filters.ageRange === '9+' ? 'active' : '' %>" data-age="9+">9+</button>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="col-lg-3 col-md-6 ps-lg-4 d-flex gap-2 justify-content-end align-items-center">
          <button type="submit" class="btn btn-apply-filters">
            APPLY FILTERS <i class="bi bi-sliders ms-1"></i>
          </button>
          <button type="button" id="btn-clear-all" class="btn btn-clear-filters">
            CLEAR
          </button>
        </div>

        <!-- Pass-through values -->
        <input type="hidden" name="category" id="activeCategoryInput" value="<%= filters.category || '' %>">
        <% if (filters.search) { %>
          <input type="hidden" name="search" value="<%= filters.search %>">
        <% } %>
      </form>
    </div>

    <!-- Category Pills Navigation Row -->
    <div class="categories-filter-scroll-wrapper mb-5">
      <div class="categories-filter-list">
        <button type="button" class="btn category-pill-btn <%= !filters.category ? 'active' : '' %>" data-category="">ALL</button>
        <% categories.forEach(cat => { %>
          <button type="button" class="btn category-pill-btn <%= filters.category === cat.slug ? 'active' : '' %>" data-category="<%= cat.slug %>">
            <%= cat.name.toUpperCase() %>
          </button>
        <% }) %>
      </div>
    </div>

    <!-- Custom Bento Product Card Grid -->
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="product-grid-container">
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
          <div class="col">
            <div class="catalog-product-card">
              <!-- Image Wrapper -->
              <div class="catalog-card-img-wrapper">
                <!-- Badges (Top Left) -->
                <% 
                  const isOutOfStock = product.stock <= 0 || product.status === 'Out of Stock';
                  const originalPrice = product.price;
                  const finalPrice = product.salePrice || product.price;
                  const hasDiscount = product.salePrice && product.salePrice < product.price;
                  const discountPct = hasDiscount ? Math.round(((product.price - product.salePrice) / product.price) * 100) : 0;
                  const primaryImg = product.images && product.images.length > 0 ? product.images[0] : '/images/placeholder.png';
                  const categoryName = product.category && product.category.name ? product.category.name : 'Toys';
                %>
                <div class="card-badge-container">
                  <% if (hasDiscount) { %>
                    <span class="badge-tag-custom bg-danger text-white"><%= discountPct %>% OFF</span>
                  <% } else if (product.isFeatured) { %>
                    <span class="badge-tag-custom bg-dark text-white">FEATURED</span>
                  <% } else if (product.isNewArrival) { %>
                    <span class="badge-tag-custom bg-primary text-white">NEW</span>
                  <% } %>
                </div>

                <!-- Quick Action / Wishlist Button (Top Right) -->
                <button class="wishlist-btn-circle" data-action="wishlist" data-product-id="<%= product._id %>">
                  <i class="bi bi-heart"></i>
                </button>

                <!-- Product Image -->
                <a href="/toys/<%= product.slug %>">
                  <img src="<%= primaryImg %>" class="catalog-card-img" alt="<%= product.title %>" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1559251606-c623743a6d76?auto=format&fit=crop&q=80&w=400';">
                </a>

                <!-- Out of stock Overlay -->
                <% if (isOutOfStock) { %>
                  <div class="out-of-stock-overlay-diagonal">
                    <span>OUT OF STOCK</span>
                  </div>
                <% } %>
              </div>

              <!-- Details -->
              <div class="catalog-card-body">
                <div class="catalog-card-category"><%= categoryName.toUpperCase() %></div>
                <h3 class="catalog-card-title">
                  <a href="/toys/<%= product.slug %>"><%= product.title %></a>
                </h3>
                <p class="catalog-card-desc"><%= product.shortDescription || 'Heirloom quality build. Designed to stimulate imagination and cognitive growth.' %></p>
                
                <div class="d-flex justify-content-between align-items-center mt-auto pt-2">
                  <div class="catalog-card-price">
                    <% if (hasDiscount) { %>
                      <span class="price-original">₹<%= originalPrice.toFixed(2) %></span>
                      <span class="price-final text-danger">₹<%= finalPrice.toFixed(2) %></span>
                    <% } else { %>
                      <span class="price-final">₹<%= finalPrice.toFixed(2) %></span>
                    <% } %>
                  </div>
                  <span class="stock-indicator <%= isOutOfStock ? 'out-of-stock' : 'in-store' %>">
                    <%= isOutOfStock ? 'Out of Stock' : 'In Store' %>
                  </span>
                </div>
              </div>

              <!-- Bottom Actions -->
              <div class="catalog-card-actions">
                <button class="btn btn-quick-view-card w-100" data-action="quick-view" data-product-id="<%= product._id %>">
                  QUICK VIEW
                </button>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-12 text-center py-5">
          <div class="py-5">
            <i class="bi bi-emoji-frown fs-1 text-muted mb-3"></i>
            <h4 class="fw-bold text-dark">No Toys Found</h4>
            <p class="text-muted">Try adjusting your filters or search criteria</p>
            <button type="button" id="btn-reset-catalog" class="btn btn-apply-filters rounded-pill mt-3 px-4">Reset Catalog</button>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Pagination -->
    <div id="pagination-container">
      <%- include('../components/pagination') %>
    </div>
  </div>
</div>

<!-- Floating WhatsApp Chat Widget -->
<a href="https://chat.whatsapp.com/FMz7qU3xDCOFlJYFw4aCYZ" target="_blank" class="floating-chat-widget">
