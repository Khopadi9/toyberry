<div class="container py-4">
  <!-- Breadcrumb -->
  <%- include('../components/breadcrumb', { breadcrumbs: [{ name: 'Catalog', url: '/toys' }] }) %>

  <!-- Top Horizontal Filter Bar -->
  <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
    <form action="/toys" method="GET" id="catalog-filter-form" class="row g-3 align-items-end">
      
      <!-- Price Range Filter Column -->
      <div class="col-md-4 col-lg-3">
        <label class="fw-bold text-muted text-uppercase mb-2 d-block" style="font-size: 0.75rem; letter-spacing: 0.5px;">Price Range</label>
        <div class="d-flex gap-2 align-items-center">
          <input type="number" name="minPrice" class="form-control rounded-pill text-center shadow-sm py-2" placeholder="Min ₹" value="<%= filters.minPrice || '' %>" min="0">
          <span class="text-muted">-</span>
          <input type="number" name="maxPrice" class="form-control rounded-pill text-center shadow-sm py-2" placeholder="Max ₹" value="<%= filters.maxPrice || '' %>" min="0">
        </div>
      </div>

      <!-- Sort Filter Column -->
      <div class="col-md-4 col-lg-3">
        <label class="fw-bold text-muted text-uppercase mb-2 d-block" style="font-size: 0.75rem; letter-spacing: 0.5px;">Sort By</label>
        <select name="sort" class="form-select rounded-pill shadow-sm py-2">
          <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest Arrivals</option>
          <option value="price-low" <%= filters.sort === 'price-low' ? 'selected' : '' %>>Price: Low to High</option>
          <option value="price-high" <%= filters.sort === 'price-high' ? 'selected' : '' %>>Price: High to Low</option>
        </select>
      </div>

      <!-- Active Search Pass-Through -->
      <% if (filters.search) { %>
        <input type="hidden" name="search" value="<%= filters.search %>">
      <% } %>

      <!-- Action Buttons Column -->
      <div class="col-md-4 col-lg-6 d-flex gap-2 justify-content-md-end justify-content-start">
        <button type="submit" class="btn btn-primary-custom rounded-pill px-4 py-2 fw-bold flex-grow-1 flex-md-grow-0">Apply Filters</button>
        <button type="button" id="btn-clear-all" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold flex-grow-1 flex-md-grow-0">Clear All</button>
      </div>

    </form>
  </div>

  <div class="row">
    <!-- Product Grid Area -->
    <div class="col-12">
      <!-- Catalog Header -->
      <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm">
        <div>
          <span class="text-muted">Showing <strong><%= products.length %></strong> toys</span>
          <% if (filters.search) { %>
            <span class="text-muted ms-2">for "<strong><%= filters.search %></strong>"</span>
          <% } %>
        </div>
      </div>

      <!-- Grid list -->
      <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="product-grid-container">
        <% if (products && products.length > 0) { %>
          <% products.forEach(product => { %>
            <div class="col">
              <%- include('../components/product-card', { product }) %>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12 text-center py-5">
            <div class="py-5">
              <i class="bi bi-emoji-frown fs-1 text-muted mb-3"></i>
              <h4 class="fw-bold">No Toys Found</h4>
              <p class="text-muted">Try adjusting your filters or search criteria</p>
              <a href="/toys" class="btn btn-primary-custom rounded-pill mt-3">Reset Catalog</a>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Pagination -->
      <div id="pagination-container">
        <%- include('../components/pagination') %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterForm = document.getElementById('catalog-filter-form');
    const productGrid = document.getElementById('product-grid-container');
    const paginationContainer = document.getElementById('pagination-container');
    const countIndicator = document.querySelector('.text-muted strong');

    // Helper to render product card client side
    function renderProductCard(product) {
      const isOutOfStock = product.stock <= 0 || product.status === 'Out of Stock';
      const originalPrice = product.price;
      const finalPrice = product.salePrice || product.price;
      const hasDiscount = product.salePrice && product.salePrice < product.price;
      const discountPct = hasDiscount ? Math.round(((product.price - product.salePrice) / product.price) * 100) : 0;
      
      const primaryImg = product.images && product.images.length > 0 ? product.images[0] : '/images/placeholder.png';
      const secondaryImg = product.images && product.images.length > 1 ? product.images[1] : primaryImg;
      
      let badgeHtml = '';
      if (product.isFeatured) {
        badgeHtml = '<span class="badge-tag badge-featured">Featured</span>';
      } else if (product.isNewArrival) {
        badgeHtml = '<span class="badge-tag badge-new">New</span>';
      } else if (product.isTrending) {
        badgeHtml = '<span class="badge-tag badge-trending">Trending</span>';
      }
      
      let discountBadge = '';
      if (hasDiscount) {
        const badgeOffsetStyle = (product.isFeatured || product.isNewArrival || product.isTrending) ? 'margin-left: 95px;' : '';
        discountBadge = `
          <span class="badge bg-danger position-absolute" style="top: 15px; left: 15px; z-index: 5; ${badgeOffsetStyle} padding: 6px 10px; font-weight: 800; font-size: 0.72rem; border-radius: var(--radius-sm);">
            ${discountPct}% OFF
          </span>
        `;
      }
      
      let priceHtml = '';
      if (hasDiscount) {
        priceHtml = `
          <div class="text-decoration-line-through text-muted" style="font-size: 0.82rem;">₹${originalPrice.toFixed(2)}</div>
          <div class="text-primary fw-extrabold fs-5">₹${finalPrice.toFixed(2)}</div>
        `;
      } else {
        priceHtml = `<div class="text-dark fw-extrabold fs-5">₹${finalPrice.toFixed(2)}</div>`;
      }
 
      let availabilityBadge = '';
      if (isOutOfStock) {
        availabilityBadge = '<span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1.5 fw-bold" style="font-size: 0.72rem; border-radius: var(--radius-sm);">Out of Stock</span>';
      } else {
        availabilityBadge = '<span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1.5 fw-bold" style="font-size: 0.72rem; border-radius: var(--radius-sm);">In Store</span>';
      }
 
      const categoryName = product.category && product.category.name ? product.category.name : 'Toys';
 
      return `
        <div class="col">
          <div class="card card-premium h-100">
            <div class="product-card-img-wrapper">
              ${badgeHtml}
              ${discountBadge}
              <a href="/toys/${product.slug}">
                <img src="${primaryImg}" class="product-card-img img-primary" alt="${product.title}" loading="lazy" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1559251606-c623743a6d76?auto=format&fit=crop&q=80&w=400';">
                <img src="${secondaryImg}" class="product-card-img img-secondary" alt="${product.title}" loading="lazy" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1559251606-c623743a6d76?auto=format&fit=crop&q=80&w=400';">
              </a>
              <div class="quick-view-overlay">
                <button class="btn btn-quick-view w-100 shadow-sm" data-action="quick-view" data-product-id="${product._id}">
                  <i class="bi bi-eye me-1"></i> Quick View
                </button>
              </div>
            </div>
            <div class="card-body d-flex flex-column">
              <div class="text-uppercase text-muted mb-1 fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">
                ${categoryName}
              </div>
              <h5 class="card-title mb-2">
                <a href="/toys/${product.slug}" class="text-dark text-decoration-none hover-color-primary fw-bold" style="font-size: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3rem; line-height: 1.5;">
                  ${product.title}
                </a>
              </h5>
              <div class="mt-auto d-flex justify-content-between align-items-center pt-2">
                <div>
                  ${priceHtml}
                </div>
                ${availabilityBadge}
              </div>
            </div>
          </div>
        </div>
      `;
    }

    // Helper to render pagination controls
    function renderPaginationControls(pagination) {
      if (!pagination || pagination.totalPages <= 1) return '';

      let html = `
        <nav aria-label="Page navigation" class="mt-5">
          <ul class="pagination justify-content-center">
      `;

      // Previous
      const prevDisabled = !pagination.hasPrevPage ? 'disabled' : '';
      html += `
        <li class="page-item ${prevDisabled}">
          <a class="page-item page-link rounded-start-pill px-3" href="#" data-page="${pagination.prevPage}" aria-label="Previous">
            <i class="bi bi-chevron-left"></i>
          </a>
        </li>
      `;

      // Pages
      for (let i = 1; i <= pagination.totalPages; i++) {
        const activeClass = pagination.page === i ? 'active' : '';
        html += `
          <li class="page-item ${activeClass}">
            <a class="page-item page-link px-3" href="#" data-page="${i}">
              ${i}
            </a>
          </li>
        `;
      }

      // Next
      const nextDisabled = !pagination.hasNextPage ? 'disabled' : '';
      html += `
        <li class="page-item ${nextDisabled}">
          <a class="page-item page-link rounded-end-pill px-3" href="#" data-page="${pagination.nextPage}" aria-label="Next">
            <i class="bi bi-chevron-right"></i>
          </a>
        </li>
      `;

      html += `
          </ul>
        </nav>
      `;

      return html;
    }

    // Function to run AJAX call
    async function updateCatalog(pageNumber = 1) {
      const formData = new FormData(filterForm);
      const params = new URLSearchParams();

      for (const [key, value] of formData.entries()) {
        if (value) {
          params.append(key, value);
        }
      }

      params.set('page', pageNumber);

      const queryString = params.toString();
      const fetchUrl = `/toys?${queryString}`;

      window.history.pushState(null, '', fetchUrl);
      productGrid.style.opacity = '0.5';

      try {
        const res = await apiRequest(fetchUrl);
        const products = res.data.products || [];
        const pagination = res.data.pagination || {};

        if (products.length === 0) {
          productGrid.innerHTML = `
            <div class="col-12 text-center py-5">
              <div class="py-5">
                <i class="bi bi-emoji-frown fs-1 text-muted mb-3"></i>
                <h4 class="fw-bold">No Toys Found</h4>
                <p class="text-muted">Try adjusting your filters or search criteria</p>
                <button type="button" id="btn-reset-catalog" class="btn btn-primary-custom rounded-pill mt-3">Reset Catalog</button>
              </div>
            </div>
          `;
        } else {
          productGrid.innerHTML = products.map(p => renderProductCard(p)).join('');
        }

        if (countIndicator) {
          countIndicator.textContent = products.length;
        }

        paginationContainer.innerHTML = renderPaginationControls(pagination);
      } catch (err) {
        showToast('Error', err.message || 'Failed to update catalog.');
      } finally {
        productGrid.style.opacity = '1';
      }
    }

    // Function to clear all filters
    function clearFilters() {
      filterForm.reset();
      // Manually clean up values
      filterForm.querySelectorAll('input').forEach(input => {
        if (input.type !== 'hidden') input.value = '';
      });
      filterForm.querySelectorAll('select').forEach(select => {
        select.selectedIndex = 0;
      });
      // Clear hidden search if any
      const searchHidden = filterForm.querySelector('input[name="search"]');
      if (searchHidden) {
        searchHidden.value = '';
      }
      const headerSearch = document.getElementById('global-search-input');
      if (headerSearch) {
        headerSearch.value = '';
      }
      updateCatalog(1);
    }

    // Listen to changes on checkboxes, radios, select dropdowns
    filterForm.querySelectorAll('input[type="radio"], select').forEach(elem => {
      elem.addEventListener('change', () => {
        updateCatalog(1);
      });
    });

    // Debounced listener on price inputs
    let priceTimeout = null;
    filterForm.querySelectorAll('input[type="number"]').forEach(elem => {
      elem.addEventListener('input', () => {
        clearTimeout(priceTimeout);
        priceTimeout = setTimeout(() => {
          updateCatalog(1);
        }, 400);
      });
    });

    // Intercept form submit
    filterForm.addEventListener('submit', (e) => {
      e.preventDefault();
      updateCatalog(1);
    });

    // Intercept clear all click
    const clearBtn = document.getElementById('btn-clear-all');
    if (clearBtn) {
      clearBtn.addEventListener('click', clearFilters);
    }

    // Delegate reset click
    document.addEventListener('click', (e) => {
      if (e.target && e.target.id === 'btn-reset-catalog') {
        clearFilters();
      }
    });

    // Intercept clicks on pagination elements
    paginationContainer.addEventListener('click', (e) => {
      const link = e.target.closest('a.page-link');
      if (link) {
        e.preventDefault();
        const page = link.getAttribute('data-page');
        if (page) {
          updateCatalog(parseInt(page));
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      }
    });
  });
</script>
