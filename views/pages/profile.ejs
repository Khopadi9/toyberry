<div class="container py-5 my-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
        <!-- User Avatar / Initial -->
        <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle mb-4 mx-auto" style="width: 80px; height: 80px; font-size: 2.5rem; font-family: var(--font-heading);">
          <%= user.name.charAt(0).toUpperCase() %>
        </div>
        
        <h3 class="fw-bold mb-1"><%= user.name %></h3>
        <span class="badge bg-secondary-subtle text-secondary px-3 py-1.5 rounded-pill mb-4 text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;"><%= user.role %></span>
        
        <!-- User Information Fields -->
        <div class="text-start mb-4 border-top pt-4">
          <div class="mb-3">
            <label class="form-label text-muted small mb-1">Email Address</label>
            <div class="fw-semibold text-dark"><%= user.email %></div>
          </div>
          <% if (user.phone) { %>
            <div class="mb-3">
              <label class="form-label text-muted small mb-1">Phone Number</label>
              <div class="fw-semibold text-dark"><%= user.phone %></div>
            </div>
          <% } %>
        </div>

        <div class="d-grid gap-3">
          <% if (user.role === 'admin') { %>
            <a href="/admin/dashboard" class="btn btn-primary-custom rounded-pill py-3 fw-bold"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a>
          <% } %>
          <a href="/logout" class="btn btn-outline-danger rounded-pill py-3 fw-bold"><i class="bi bi-box-arrow-right me-2"></i>Log Out</a>
        </div>
      </div>
    </div>
  </div>
</div>
