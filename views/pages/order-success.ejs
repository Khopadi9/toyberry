<div class="container py-5 text-center">
  <div class="row justify-content-center">
    <div class="col-md-6 py-5">
      <div class="mb-4">
        <!-- Playful dynamic checkmark illustration -->
        <div class="d-inline-flex align-items-center justify-content-center bg-success-subtle text-success rounded-circle" style="width: 100px; height: 100px; font-size: 3.5rem;">
          <i class="bi bi-check-lg"></i>
        </div>
      </div>

      <h1 class="fw-bold mb-3">Order Placed Successfully!</h1>
      <p class="text-muted fs-5 mb-4">
        Thank you for shopping at ToyBerry. Your kids will love their new premium toys!
      </p>

      <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-light">
        <h6 class="text-muted mb-2 text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">Your Order Number</h6>
        <h3 class="fw-extrabold text-primary mb-0"><%= orderNumber %></h3>
        <p class="text-muted small mt-2 mb-0">We have sent a confirmation email with invoice details.</p>
      </div>

      <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
        <a href="/order/track?orderNumber=<%= orderNumber %>" class="btn btn-primary-custom rounded-pill px-4 py-3 fw-bold">
          <i class="bi bi-truck me-2"></i> Track Your Order
        </a>
        <a href="/" class="btn btn-outline-secondary rounded-pill px-4 py-3 fw-bold">
          Continue Shopping
        </a>
      </div>
    </div>
  </div>
</div>
