<!-- Footer Ajax Newsletter subscription and dynamic script bindings -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 2. Custom FAQ Accordion Toggler
    document.querySelectorAll('.faq-btn-custom').forEach(button => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling;
        const icon = button.querySelector('.faq-icon-custom');
        const isHidden = content.classList.contains('d-none');
        
        // Close all other accordion items
        document.querySelectorAll('.faq-content-custom').forEach(c => c.classList.add('d-none'));
        document.querySelectorAll('.faq-icon-custom').forEach(i => {
          i.classList.remove('rotate-45');
        });

        // Toggle clicked item
        if (isHidden) {
          content.classList.remove('d-none');
          icon.classList.add('rotate-45');
        }
      });
    });

    // 3. Countdown timer logic
    const countdownEl = document.getElementById('flash-deal-countdown');
    if (countdownEl) {
      const endTimeStr = countdownEl.getAttribute('data-end-time');
      const endTime = new Date(endTimeStr).getTime();

      const hoursVal = document.getElementById('cd-hours');
      const minsVal = document.getElementById('cd-mins');
      const secsVal = document.getElementById('cd-secs');

      function updateCountdown() {
        const now = new Date().getTime();
        const diff = endTime - now;

        if (diff <= 0) {
          clearInterval(timerInterval);
          if (hoursVal) hoursVal.textContent = '00';
          if (minsVal) minsVal.textContent = '00';
          if (secsVal) secsVal.textContent = '00';
          return;
        }

        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const secs = Math.floor((diff % (1000 * 60)) / 1000);

        if (hoursVal) hoursVal.textContent = hours.toString().padStart(2, '0');
        if (minsVal) minsVal.textContent = mins.toString().padStart(2, '0');
        if (secsVal) secsVal.textContent = secs.toString().padStart(2, '0');
      }

      updateCountdown();
      const timerInterval = setInterval(updateCountdown, 1000);
    }

    // 4. Scroll Animation Observer for product cards and reveal animations
    const revealElements = document.querySelectorAll('.animate-left, .animate-right, .reveal-fade-up, .reveal-scale-in, .reveal-fade-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          entry.target.classList.add('revealed');
          // Stop observing to improve scroll performance
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.08,
      rootMargin: "0px 0px -40px 0px"
    });
    revealElements.forEach(el => observer.observe(el));

    // 5. Cinematic Video Modal Toggler
    const playVideoBtn = document.getElementById('playVideoBtn');
    const videoModal = document.getElementById('videoModal');
    const closeVideoBtn = document.getElementById('closeVideoBtn');
    const videoPlayerFrame = document.getElementById('videoPlayerFrame');

    if (playVideoBtn && videoModal && closeVideoBtn && videoPlayerFrame) {
      playVideoBtn.addEventListener('click', (e) => {
        const href = playVideoBtn.getAttribute('href');
        
        // If it is a channel link (cannot be embedded in iframes), open in new tab
        if (href.includes('/@') || href.includes('/channel/') || href.includes('/user/')) {
          return; // Let the browser handle standard anchor navigation to _blank
        }
        
        e.preventDefault();
        let embedUrl = href;
        if (href.includes('youtube.com/watch?v=')) {
          const videoId = href.split('v=')[1].split('&')[0];
          embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
        } else if (href.includes('youtu.be/')) {
          const videoId = href.split('youtu.be/')[1].split('?')[0];
          embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
        } else if (!href.includes('embed')) {
          embedUrl = "https://www.youtube.com/embed/iJ-rXAGwz78?autoplay=1";
        }
        
        videoPlayerFrame.src = embedUrl;
        videoModal.classList.remove('d-none');
        setTimeout(() => {
          videoModal.style.opacity = '1';
        }, 10);
      });

      closeVideoBtn.addEventListener('click', () => {
        videoModal.style.opacity = '0';
        setTimeout(() => {
          videoModal.classList.add('d-none');
          videoPlayerFrame.src = "";
        }, 300);
      });

      // Close modal when clicking outside the video container
      videoModal.addEventListener('click', (e) => {
        if (e.target === videoModal) {
          closeVideoBtn.click();
        }
      });
    }
  });
</script>