<!-- Flash Deals / Special Deal Banner (Coral Gradient) -->
<% let flashToys=toys.dealsOfTheWeek || []; if (flashToys.length===0) { const discountedToys=[]; if (toys.featured) {
  discountedToys.push(...toys.featured.filter(t=> t.salePrice && t.salePrice < t.price)); } if (toys.trending) {
    discountedToys.push(...toys.trending.filter(t=> t.salePrice && t.salePrice < t.price)); }
      flashToys=discountedToys.slice(0, 10); } if (flashToys.length===0 && toys.featured && toys.featured.length> 0) {
      flashToys = toys.featured.slice(0, 10).map(t => {
      const cloned = t.toObject ? t.toObject() : JSON.parse(JSON.stringify(t));
      cloned.salePrice = Math.round(cloned.price * 0.85);
      return cloned;
      });
      }
      %>
      <% if (flashToys.length> 0) { %>
        <style>
          .deals-carousel-item {
            flex: 0 0 calc(33.333% - 14px);
            min-width: 250px;
            transition: transform 0.3s ease, opacity 0.3s ease;
          }

          @media (max-width: 991px) {
            .deals-carousel-item {
              flex: 0 0 calc(50% - 10px);
            }
          }

          @media (max-width: 576px) {
            .deals-carousel-item {
              flex: 0 0 100%;
            }
          }

          #deal-prev-btn:hover,
          #deal-next-btn:hover {
            background-color: rgba(255, 255, 255, 0.2);
