                <h2 class="fw-extrabold text-white mb-3" style="font-size: 2.4rem;">Deals of the Week</h2>
                <p class="text-white-50 mb-4">Hurry! Grab these premium toys at limited-time discounted prices before
                  stock runs out.</p>

                <!-- Countdown Timer -->
                <div class="d-flex gap-3 mb-4" id="flash-deal-countdown"
                  data-end-time="<%= new Date(Date.now() + 86400 * 3000).toISOString() %>">
                  <div class="countdown-box">
                    <h3 id="cd-hours">72</h3>
                    <span>Hours</span>
                  </div>
                  <div class="countdown-box">
                    <h3 id="cd-mins">00</h3>
                    <span>Mins</span>
                  </div>
                  <div class="countdown-box">
                    <h3 id="cd-secs">00</h3>
                    <span>Secs</span>
                  </div>
                </div>
              </div>
              <div class="col-lg-8 position-relative">
                <div class="d-flex justify-content-end align-items-center gap-3 mb-3">
                  <span id="deals-carousel-counter"
                    style="color: rgba(255, 255, 255, 0.7); font-size: 0.9rem; font-weight: 700; font-family: monospace; letter-spacing: 0.5px;"></span>
                  <button type="button" onclick="window.dealsCarouselState.slide('prev')"
                    class="btn btn-outline-light rounded-circle p-0 d-flex align-items-center justify-content-center"
                    id="deal-prev-btn"
                    style="width: 40px; height: 40px; display: flex; position: relative; z-index: 10; pointer-events: auto !important; cursor: pointer;"
                    aria-label="Previous Deal">
                    <i class="bi bi-chevron-left fs-5" style="pointer-events: none;"></i>
                  </button>
                  <button type="button" onclick="window.dealsCarouselState.slide('next')"
                    class="btn btn-outline-light rounded-circle p-0 d-flex align-items-center justify-content-center"
                    id="deal-next-btn"
                    style="width: 40px; height: 40px; display: flex; position: relative; z-index: 10; pointer-events: auto !important; cursor: pointer;"
                    aria-label="Next Deal">
                    <i class="bi bi-chevron-right fs-5" style="pointer-events: none;"></i>
                  </button>
                </div>
                <div class="deals-carousel-viewport" style="overflow: hidden; width: 100%; touch-action: pan-y;">
                  <div class="deals-carousel-track d-flex flex-nowrap"
                    style="transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1); gap: 20px; flex-wrap: nowrap !important; transform: translate3d(0, 0, 0); will-change: transform;">
                    <% flashToys.forEach((product)=> { %>
                      <div class="deals-carousel-item" style="flex-shrink: 0 !important;">
                        <%- include('../components/product-card', { product, showDiscountBadge: true }) %>
                      </div>
                      <% }) %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <script>
          (function () {
            window.dealsCarouselState = {
              currentIndex: 0,
              getVisibleItems: function () {
                if (window.innerWidth <= 576) return 1;
                if (window.innerWidth <= 991) return 2;
                return 3;
              },
              slide: function (direction) {
                const track = document.querySelector('.deals-carousel-track');
                if (!track) return;
                const items = track.querySelectorAll('.deals-carousel-item');
                if (items.length === 0) return;

                const totalItems = items.length;
                const visibleItems = this.getVisibleItems();
                const maxIndex = Math.max(0, totalItems - visibleItems);

                if (maxIndex === 0) return;

                if (direction === 'next') {
                  if (this.currentIndex < maxIndex) {
                    this.currentIndex++;
                  } else {
                    this.currentIndex = 0;
                  }
                } else if (direction === 'prev') {
                  if (this.currentIndex > 0) {
                    this.currentIndex--;
                  } else {
                    this.currentIndex = maxIndex;
                  }
                }
                this.update();
              },
              update: function () {
                const track = document.querySelector('.deals-carousel-track');
                const prevBtn = document.getElementById('deal-prev-btn');
                const nextBtn = document.getElementById('deal-next-btn');
                const viewport = document.querySelector('.deals-carousel-viewport');
                const counter = document.getElementById('deals-carousel-counter');
                if (!track || !viewport) return;

                const items = track.querySelectorAll('.deals-carousel-item');
                if (items.length === 0) return;

                const totalItems = items.length;
                const visibleItems = this.getVisibleItems();
                const maxIndex = Math.max(0, totalItems - visibleItems);

                if (maxIndex === 0) {
                  if (prevBtn) prevBtn.style.display = 'none';
                  if (nextBtn) nextBtn.style.display = 'none';
                  track.style.transform = 'translate3d(0, 0, 0)';
                  if (counter) counter.textContent = '';
                  return;
                } else {
                  if (prevBtn) prevBtn.style.display = 'flex';
                  if (nextBtn) nextBtn.style.display = 'flex';
                }

                if (this.currentIndex > maxIndex) {
                  this.currentIndex = maxIndex;
                }

                const firstItem = items[0];
                const itemWidth = firstItem.getBoundingClientRect().width || firstItem.offsetWidth;
                const computedStyle = window.getComputedStyle(track);
                const gap = parseFloat(computedStyle.gap) || 20;

                const amountToMove = this.currentIndex * (itemWidth + gap);
                track.style.transform = `translate3d(-${amountToMove}px, 0, 0)`;

                if (counter) {
                  counter.textContent = `${this.currentIndex + 1} / ${maxIndex + 1}`;
                }
              }
            };

            // Set up listeners
            if (window.ResizeObserver) {
              const viewport = document.querySelector('.deals-carousel-viewport');
              if (viewport) {
                const observer = new ResizeObserver(() => {
                  window.dealsCarouselState.update();
                });
                observer.observe(viewport);
              }
            } else {
              window.addEventListener('resize', () => window.dealsCarouselState.update());
            }

            window.addEventListener('load', () => window.dealsCarouselState.update());
            document.addEventListener('DOMContentLoaded', () => window.dealsCarouselState.update());

            // Touch swipe detection for mobile users
            let touchStartX = 0;
            let touchStartY = 0;
            let touchEndX = 0;
            let touchEndY = 0;

            const viewportEl = document.querySelector('.deals-carousel-viewport');
            if (viewportEl) {
              viewportEl.addEventListener('touchstart', (e) => {
                touchStartX = e.touches[0].clientX;
                touchStartY = e.touches[0].clientY;
              }, { passive: true });

              viewportEl.addEventListener('touchend', (e) => {
                touchEndX = e.changedTouches[0].clientX;
                touchEndY = e.changedTouches[0].clientY;

                const thresholdX = 40; // minimum horizontal swipe distance
                const thresholdY = 60; // maximum vertical deviation to ignore swipe if scrolling the page
                const diffX = touchStartX - touchEndX;
                const diffY = Math.abs(touchStartY - touchEndY);

                if (Math.abs(diffX) > thresholdX && diffY < thresholdY) {
                  if (diffX > 0) {
                    window.dealsCarouselState.slide('next');
                  } else {
                    window.dealsCarouselState.slide('prev');
                  }
                }
              }, { passive: true });
            }

            // Initial settles
            window.dealsCarouselState.update();
            setTimeout(() => window.dealsCarouselState.update(), 100);
            setTimeout(() => window.dealsCarouselState.update(), 500);
            setTimeout(() => window.dealsCarouselState.update(), 1000);
          })();
        </script>
        <% } %>

