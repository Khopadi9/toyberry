<% if (locals.faqs && faqs.length > 0) { %>
  <section class="container py-5 my-5">
    <div class="faq-row-layout">
      <!-- FAQ Left: Sticky title and support concierge block -->
      <div class="faq-left-col reveal-fade-up">
        <h2 class="featured-collections-title text-black" style="font-size: 3.5rem; line-height: 1.1;">Frequently <br>Asked Questions</h2>
        <p class="fs-5 text-muted mb-5 mt-3" style="max-width: 320px;">Everything you need to know about our sourcing, shipping, and heirloom return policies.</p>
        
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center justify-content-center bg-danger rounded-circle text-white" style="width: 50px; height: 50px;">
            <i class="bi bi-headset fs-4 text-white"></i>
          </div>
          <div>
            <p class="fw-bold mb-1 text-black">Still have questions?</p>
            <a href="/contact" class="text-danger hover-underline fw-bold text-decoration-none">Contact our concierge team</a>
          </div>
        </div>
      </div>

      <!-- FAQ Right: Accordion items custom styled -->
      <div class="faq-right-col mt-4 mt-md-0">
        <% faqs.forEach((faq, index) => { %>
          <div class="faq-item-custom reveal-fade-up delay-<%= (index % 5) * 100 %>">
            <button class="faq-btn-custom" type="button">
              <span><%= faq.question %></span>
              <i class="bi bi-plus-lg faq-icon-custom"></i>
            </button>
            <div class="faq-content-custom d-none">
              <%= faq.answer %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
<% } else { %>
  <!-- Premium Fallback FAQs if Database FAQs not populated -->
  <section class="container py-5 my-5">
    <div class="faq-row-layout">
      <div class="faq-left-col">
        <h2 class="featured-collections-title text-black" style="font-size: 3.5rem; line-height: 1.1;">Frequently <br>Asked Questions</h2>
        <p class="fs-5 text-muted mb-5 mt-3" style="max-width: 320px;">Everything you need to know about our sourcing, shipping, and heirloom return policies.</p>
        
        <div class="d-flex align-items-center gap-3">
          <div class="d-flex align-items-center justify-content-center bg-danger rounded-circle text-white" style="width: 50px; height: 50px;">
            <i class="bi bi-headset fs-4 text-white"></i>
          </div>
          <div>
            <p class="fw-bold mb-1 text-black">Still have questions?</p>
            <a href="/contact" class="text-danger hover-underline fw-bold text-decoration-none">Contact our concierge team</a>
          </div>
        </div>
      </div>

      <div class="faq-right-col mt-4 mt-md-0">
        <div class="faq-item-custom">
          <button class="faq-btn-custom" type="button">
            <span>Where do you source your toys?</span>
            <i class="bi bi-plus-lg faq-icon-custom"></i>
          </button>
          <div class="faq-content-custom d-none">
            We partner with over 450 artisan makers and heritage brands globally, focusing on sustainable materials, ethical labor, and timeless design quality.
          </div>
        </div>
        <div class="faq-item-custom">
          <button class="faq-btn-custom" type="button">
            <span>How fast is international shipping?</span>
            <i class="bi bi-plus-lg faq-icon-custom"></i>
          </button>
          <div class="faq-content-custom d-none">
            We offer express 48-hour delivery to major global hubs and standard tracked shipping (5-7 days) everywhere else.
          </div>
        </div>
        <div class="faq-item-custom">
          <button class="faq-btn-custom" type="button">
            <span>What is your "Heirloom Guarantee"?</span>
            <i class="bi bi-plus-lg faq-icon-custom"></i>
          </button>
          <div class="faq-content-custom d-none">
            Our Heirloom Guarantee means we offer lifetime repairs on any wooden toy purchased from us, ensuring it can be passed down for generations.
          </div>
        </div>
        <div class="faq-item-custom">
          <button class="faq-btn-custom" type="button">
            <span>Do you offer gift wrapping?</span>
            <i class="bi bi-plus-lg faq-icon-custom"></i>
          </button>
          <div class="faq-content-custom d-none">
            Yes, we provide bespoke gift wrapping with recycled materials and hand-lettered cards for a truly premium unboxing experience.
          </div>
        </div>
      </div>
    </div>
  </section>
<% } %>

<!-- WhatsApp Community Bento banner -->
