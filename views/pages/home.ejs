<!-- Full-width Premium Hero Carousel -->
<div id="heroCarousel" class="carousel slide container-fluid p-0 mb-4 hero-section" data-bs-ride="carousel"
  data-bs-interval="6000">
  <div class="carousel-inner">
    <% if (locals.banners && banners.length> 0) { %>
      <% banners.forEach((banner, index)=> { %>
        <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
          <div class="carousel-hero-item" style="background-image: url('<%= banner.image %>'); cursor: pointer;"
            onclick="window.location.href='<%= banner.link || '/toys' %>'">
            <div class="carousel-hero-overlay">
              <div class="container">
                <div class="carousel-hero-content">
                  <span class="badge-hero">Exclusive Collection</span>
                  <h1 class="display-3 fw-black mb-3 text-white">
                    <%= banner.title %>
                  </h1>
                  <p class="fs-5 mb-4 text-white-50">
                    <%= banner.subtitle %>
                  </p>
                  <div class="d-flex gap-3" onclick="event.stopPropagation();">
                    <a href="<%= banner.link || '/toys' %>" class="btn-pill btn-coral">Shop Collection</a>
                    <a href="/toys" class="btn-pill btn-outline-white">View All Toys</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
          <% } else { %>
            <!-- Premium Fallback Slide -->
            <div class="carousel-item active">
              <div class="carousel-hero-item"
                style="background-image: url('https://images.unsplash.com/photo-1596461404969-9ae70f2830c1?auto=format&fit=crop&q=80&w=1600'); cursor: pointer;"
                onclick="window.location.href='/toys'">
                <div class="carousel-hero-overlay">
                  <div class="container">
                    <div class="carousel-hero-content">
                      <span class="badge-hero">Welcome to ToyBerry</span>
                      <h1 class="display-3 mb-3 text-white">Premium Toys for Growing Minds</h1>
                      <p class="fs-5 mb-4 text-white-50">Explore curated educational, STEM, and creative play sets from
                        Hamleys, LEGO, and Melissa & Doug.</p>
                      <div class="d-flex gap-3" onclick="event.stopPropagation();">
                        <a href="/toys" class="btn-pill btn-coral">Shop Catalog</a>
                        <a href="/about" class="btn-pill btn-outline-white">Our Story</a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <% } %>
  </div>

  <!-- Carousel Navigation Controls -->
  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <i class="bi bi-chevron-left fs-3"></i>
    <span class="visually-hidden">Previous</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <i class="bi bi-chevron-right fs-3"></i>
    <span class="visually-hidden">Next</span>
  </button>
</div>

