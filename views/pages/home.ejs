      <a href="https://chat.whatsapp.com/FMz7qU3xDCOFlJYFw4aCYZ" target="_blank" class="btn whatsapp-btn-custom">
        <i class="bi bi-whatsapp fs-5"></i> JOIN COMMUNITY
      </a>
    </div>
  </div>
