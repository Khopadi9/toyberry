<div class="container py-5">
  <h1 class="fw-bold mb-4">My Wishlist</h1>

  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    <% if (products && products.length > 0) { %>
      <% products.forEach(product => { %>
        <div class="col" id="wishlist-item-<%= product._id %>">
          <div class="position-relative">
            <%- include('../components/product-card', { product }) %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <i class="bi bi-heartbreak fs-1 text-muted mb-3"></i>
        <h3 class="fw-bold">Your Wishlist is Empty</h3>
        <p class="text-muted mb-4">Add your favorite luxury toys to keep track of them!</p>
        <a href="/toys" class="btn btn-primary-custom rounded-pill px-5">Explore Toys</a>
      </div>
    <% } %>
  </div>
</div>
