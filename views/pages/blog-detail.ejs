<div class="container py-4">
  <%- include('../components/breadcrumb', { breadcrumbs: [
    { name: 'Blog', url: '/blog' },
    { name: blog.title, url: '#' }
  ]}) %>

  <div class="row">
    <!-- Article view -->
    <div class="col-lg-8 mb-5">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
        <% if (blog.image) { %>
          <img src="<%= blog.image %>" class="img-fluid w-100" style="max-height: 400px; object-fit: cover;" alt="<%= blog.title %>">
        <% } %>
        <div class="card-body p-5">
          <div class="d-flex align-items-center gap-3 mb-3">
            <span class="badge bg-primary-subtle text-primary" style="font-size: 0.8rem; padding: 6px 12px;"><%= blog.category %></span>
            <small class="text-muted"><i class="bi bi-calendar-event me-1"></i> <%= new Date(blog.createdAt).toLocaleDateString() %></small>
            <small class="text-muted"><i class="bi bi-person me-1"></i> By <%= blog.author %></small>
          </div>
          
          <h1 class="fw-bold mb-4"><%= blog.title %></h1>
          
          <div class="lh-lg text-muted fs-6" style="white-space: pre-line;">
            <%= blog.content %>
          </div>

          <!-- Tags list -->
          <% if (blog.tags && blog.tags.length > 0) { %>
            <div class="mt-4 pt-3 border-top d-flex flex-wrap gap-2 align-items-center">
              <span class="text-muted small fw-bold me-2"><i class="bi bi-tags-fill me-1"></i> Tags:</span>
              <% blog.tags.forEach(tag => { %>
                <a href="/blog?tag=<%= tag %>" class="btn btn-sm btn-outline-secondary rounded-pill px-3"><%= tag %></a>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Related articles list -->
      <% if (related && related.length > 0) { %>
        <section class="mt-5">
          <h4 class="fw-bold mb-4">Related Articles</h4>
          <div class="row g-4">
            <% related.forEach(relPost => { %>
              <div class="col-md-4">
                <div class="card card-premium h-100">
                  <img src="<%= relPost.image || '/images/placeholder-blog.png' %>" class="card-img-top" alt="<%= relPost.title %>" style="height: 140px; object-fit: cover;">
                  <div class="card-body p-3">
                    <h6 class="fw-bold mb-2" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><a href="/blog/<%= relPost.slug %>" class="text-dark text-decoration-none"><%= relPost.title %></a></h6>
                    <small class="text-muted"><%= new Date(relPost.createdAt).toLocaleDateString() %></small>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </section>
      <% } %>
    </div>

    <!-- Right Sidebar Widgets -->
    <div class="col-lg-4">
      <div class="sticky-top" style="top: 110px;">
        <!-- Popular posts widget -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
          <h5 class="fw-bold mb-3">Popular Articles</h5>
          <div class="d-flex flex-column gap-3">
            <% popular.forEach(post => { %>
              <div class="d-flex align-items-center">
                <img src="<%= post.image || '/images/placeholder-blog.png' %>" class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover;">
                <div>
                  <h6 class="fw-bold mb-0" style="font-size: 0.85rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    <a href="/blog/<%= post.slug %>" class="text-dark text-decoration-none"><%= post.title %></a>
                  </h6>
                  <small class="text-muted" style="font-size: 0.7rem;"><%= new Date(post.createdAt).toLocaleDateString() %></small>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
